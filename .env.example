# ============================================================
# SeloPay — variáveis de ambiente (EXEMPLO)
# Copie para .env e preencha com seus valores
# ============================================================

# Banco de dados
DATABASE_URL="postgresql://selopay:selopay_dev_pass@localhost:5435/selopay?schema=public"

# JWT
JWT_SECRET="selopay_jwt_secret_change_in_production"
JWT_EXPIRES_IN="7d"

# JWT Admin
ADMIN_JWT_SECRET="selopay_admin_jwt_secret_change_in_production"
ADMIN_JWT_EXPIRES_IN="1d"

# API
PORT=3333
NODE_ENV=development

# CORS — origens permitidas (separar por vírgula)
CORS_ORIGINS="http://localhost:3000,http://localhost:19006"

# Seed (usuário admin padrão)
ADMIN_EMAIL="admin@selopay.com"
ADMIN_PASSWORD="Admin@123"
